{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/backend/server.js"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "/backend/uploads/$1"
    }
  ],
  "functions": {
    "backend/server.js": {
      "runtime": "vercel-node@latest",
      "includeFiles": "backend/database.sqlite"
    }
  }
}
